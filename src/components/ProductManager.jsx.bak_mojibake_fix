    const handlePayload = (incoming) => {
      if (!incoming || incoming.source !== XHS_SEO_SYNC_SOURCE) return
      if (incoming.type === 'data' && incoming.data) {
        setSeoKeywordSyncOpen(true)
        if (incoming.data.seedKeyword) {
