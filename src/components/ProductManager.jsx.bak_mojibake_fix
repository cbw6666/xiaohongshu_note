const XHS_SEO_SYNC_SOURCE = 'xhs-seo-keyword-sync'
const XHS_SEO_SYNC_CHANNEL = 'xhs-seo-keyword-sync'
const XHS_MAX_IMPORTED_KEYWORDS = 30
const XHS_SOURCE_SCORE_MAP = {
  suggest: 1.8,
  recommend: 1.5,
  trending: 1.5,
  hashtag: 1.2,
  manual: 1.5,
}
const XHS_NOISE_KEYWORDS = new Set([
  'all', 'image', 'video', 'user', 'discover', 'follow', 'message', 'live', 'publish',
  'search', 'recommend', 'related', 'more', 'back', 'login', 'register', 'settings',
  'home', 'official', 'ad', 'note',
])

const splitKeywordText = (input = '') =>
  String(input || '')
    .split(/\r?\n|,|，/)
    .map((item) => item.trim())
    .filter(Boolean)

const normalizeKeywordWord = (raw = '') =>
  String(raw || '')
    .replace(/^[#＃]+/, '')
    .replace(/[\u200B-\u200D\uFEFF]/g, '')
    .replace(/[|]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()

const normalizeKeywordKey = (raw = '') => normalizeKeywordWord(raw).toLowerCase()

const isLikelyNoiseKeyword = (word = '', seedKeyword = '') => {
  if (!word) return true
  if (word.length < 2 || word.length > 20) return true
  if (/^\d+$/.test(word)) return true
  if (/^[\W_]+$/.test(word)) return true
  if (XHS_NOISE_KEYWORDS.has(word.toLowerCase())) return true
  if (normalizeKeywordKey(word) === normalizeKeywordKey(seedKeyword)) return true
  if (/^(click|open|copy|paste|input|output|view|retry|confirm|cancel)$/i.test(word)) return true
  return false
}

const pickSeoSeedKeyword = (seoForm, product) => {
  const fromForm = normalizeKeywordWord(seoForm?.seedKeyword || '')
  if (fromForm) return fromForm
  const fromCore = normalizeKeywordWord(seoForm?.coreKeyword || '')
  if (fromCore) return fromCore
  return normalizeKeywordWord(product?.name || '')
}

const sanitizeImportedKeywords = (payload = {}) => {
  const fallbackSeed = normalizeKeywordWord(payload?.seedKeyword || '')
  const rawList = Array.isArray(payload?.keywords) ? payload.keywords : []
  const unique = []
  const seen = new Set()

  rawList.forEach((item) => {
    const wordRaw = typeof item === 'string' ? item : item?.word
    const sourceRaw = typeof item === 'string' ? 'manual' : (item?.source || 'manual')
    const word = normalizeKeywordWord(wordRaw)
    const source = String(sourceRaw || 'manual').toLowerCase()
    const scoreDefault = XHS_SOURCE_SCORE_MAP[source] || XHS_SOURCE_SCORE_MAP.manual
    const parsedScore = Number(typeof item === 'string' ? NaN : item?.score)
    const score = Number.isFinite(parsedScore) ? Math.max(0.5, Math.min(3, parsedScore)) : scoreDefault

    if (isLikelyNoiseKeyword(word, fallbackSeed)) return
    const key = normalizeKeywordKey(word)
    if (!key || seen.has(key)) return

    seen.add(key)
    unique.push({ word, source, score })
  })

  return {
    seedKeyword: fallbackSeed,
    keywords: unique.slice(0, XHS_MAX_IMPORTED_KEYWORDS),
  }
}

const mergeLongTailKeywordsText = (existingText = '', incomingKeywords = []) => {
  const merged = []
  const seen = new Set()
  const appendWord = (word) => {
    const normalized = normalizeKeywordWord(word)
    const key = normalizeKeywordKey(normalized)
    if (!normalized || !key || seen.has(key)) return
    seen.add(key)
    merged.push(normalized)
  }

  splitKeywordText(existingText).forEach(appendWord)
  incomingKeywords.forEach((item) => appendWord(item.word))
  return merged.join('\n')
}

const mergeLongTailPoolText = (existingPoolText = '', incomingKeywords = []) => {
  const existing = Array.isArray(keywordTextToPool(existingPoolText)) ? keywordTextToPool(existingPoolText) : []
  const order = []
  const mergedMap = new Map()

  existing.forEach((item) => {
    const word = normalizeKeywordWord(item?.word)
    const key = normalizeKeywordKey(word)
    if (!word || !key || mergedMap.has(key)) return
    const weight = Number.isFinite(Number(item?.weight)) ? Math.max(0.1, Math.min(10, Number(item.weight))) : 1
    mergedMap.set(key, { word, weight, locked: Boolean(item?.locked) })
    order.push(key)
  })

  incomingKeywords.forEach((item) => {
    const word = normalizeKeywordWord(item?.word)
    const key = normalizeKeywordKey(word)
    if (!word || !key) return
    const targetWeight = Number.isFinite(Number(item?.score)) ? Number(item.score) : XHS_SOURCE_SCORE_MAP.manual

    if (!mergedMap.has(key)) {
      mergedMap.set(key, {
        word,
        weight: Math.max(0.1, Math.min(10, targetWeight)),
        locked: false,
      })
      order.push(key)
      return
    }

    const prev = mergedMap.get(key)
    mergedMap.set(key, {
      ...prev,
      weight: Math.max(prev.weight || 1, Math.max(0.1, Math.min(10, targetWeight))),
    })
  })

  const finalPool = order.map((key) => mergedMap.get(key)).filter(Boolean)
  return keywordPoolToText(finalPool)
}

const buildXhsKeywordSyncScript = (seedKeyword) => {
  const safeSeed = JSON.stringify(String(seedKeyword || ''))
  return `(function () {
  var SOURCE = '${XHS_SEO_SYNC_SOURCE}';
  var CHANNEL = '${XHS_SEO_SYNC_CHANNEL}';
  var MAX_COUNT = ${XHS_MAX_IMPORTED_KEYWORDS};
  var seedKeyword = ${safeSeed};
  var sourceScoreMap = { suggest: 1.8, recommend: 1.5, trending: 1.5, hashtag: 1.2, manual: 1.5 };
  var stopWords = {
    all: 1, image: 1, video: 1, user: 1, discover: 1, follow: 1, message: 1, live: 1,
    publish: 1, search: 1, recommend: 1, related: 1, more: 1, back: 1, login: 1,
    register: 1, settings: 1, home: 1, official: 1, ad: 1, note: 1
  };

  function normalizeWord(raw) {
    return String(raw || '')
      .replace(/^[#＃]+/, '')
      .replace(/[\\u200B-\\u200D\\uFEFF]/g, '')
      .replace(/[|]+/g, ' ')
      .replace(/\\s+/g, ' ')
      .trim();
  }

  function keyOf(word) {
    return normalizeWord(word).toLowerCase();
  }

  function isNoise(word) {
    if (!word) return true;
    if (word.length < 2 || word.length > 20) return true;
    if (/^\\d+$/.test(word)) return true;
    if (/^[\\W_]+$/.test(word)) return true;
    if (stopWords[keyOf(word)]) return true;
    if (keyOf(word) === keyOf(seedKeyword)) return true;
    return false;
  }

  function splitCandidateText(text) {
    return String(text || '')
      .split(/[\\n\\r\\t,，、|/\\-]+/)
      .map(function (part) { return normalizeWord(part); })
      .filter(Boolean);
  }

  var list = [];
  var seen = {};
  function pushWord(rawWord, source, score) {
    var word = normalizeWord(rawWord);
    if (isNoise(word)) return;
    var key = keyOf(word);
    if (!key || seen[key]) return;
    seen[key] = 1;
    list.push({
      word: word,
      source: source || 'manual',
      score: Number(score) || sourceScoreMap[source] || 1.5
    });
  }

  function inferSourceByPath(path) {
    var p = String(path || '').toLowerCase();
    if (/(suggest|sug|hint)/.test(p)) return 'suggest';
    if (/(recommend|related|card|onebox)/.test(p)) return 'recommend';
    if (/(trend|hot|query)/.test(p)) return 'trending';
    return 'manual';
  }

  function scanState(node, path, depth) {
    if (!node || depth > 6) return;
    if (Array.isArray(node)) {
      node.forEach(function (item, index) {
        scanState(item, path + '[' + index + ']', depth + 1);
      });
      return;
    }
    if (typeof node !== 'object') return;

    Object.keys(node).forEach(function (key) {
      var value = node[key];
      var nextPath = path ? path + '.' + key : key;
      var source = inferSourceByPath(nextPath);

      if (typeof value === 'string') {
        if (/(suggest|sug|hint|recommend|related|trend|hot|query|keyword|word)/i.test(key)) {
          splitCandidateText(value).forEach(function (word) {
            pushWord(word, source, sourceScoreMap[source] || 1.5);
          });
        }
        return;
      }

      if (Array.isArray(value) && /(suggest|sug|hint|recommend|related|trend|hot|query|keyword|word)/i.test(key)) {
        value.forEach(function (item) {
          if (typeof item === 'string') {
            splitCandidateText(item).forEach(function (word) {
              pushWord(word, source, sourceScoreMap[source] || 1.5);
            });
            return;
          }
          if (!item || typeof item !== 'object') return;
          var candidates = [item.word, item.searchWord, item.keyword, item.query, item.text, item.title, item.name];
          candidates.forEach(function (candidate) {
            splitCandidateText(candidate).forEach(function (word) {
              pushWord(word, source, sourceScoreMap[source] || 1.5);
            });
          });
        });
      }

      scanState(value, nextPath, depth + 1);
    });
  }

  function parseFromState() {
    try {
      var state = window.__INITIAL_STATE__ || {};
      scanState(state.search || state, 'state.search', 0);
    } catch (err) {
      console.warn('[SEO keyword sync] parse __INITIAL_STATE__ failed', err);
    }
  }

  function parseFromDom() {
    var selectorGroups = [
      { selector: '[class*="suggest"] *', source: 'suggest' },
      { selector: '[class*="recommend"] *', source: 'recommend' },
      { selector: '[class*="related"] *', source: 'recommend' },
      { selector: '[class*="trend"] *', source: 'trending' },
      { selector: '[class*="hot"] *', source: 'trending' },
      { selector: '[class*="query"] *', source: 'trending' }
    ];

    selectorGroups.forEach(function (group) {
      try {
        var els = document.querySelectorAll(group.selector);
        els.forEach(function (el) {
          var text = normalizeWord(el.textContent || '');
          if (!text) return;
          splitCandidateText(text).forEach(function (word) {
            pushWord(word, group.source, sourceScoreMap[group.source] || 1.5);
          });
        });
      } catch (err) {
        console.warn('[SEO keyword sync] read DOM failed', group.selector, err);
      }
    });
  }

  function parseFromHashtags() {
    try {
      var rawText = (document.body && document.body.innerText) || '';
      var matches = rawText.match(/#[^\\s#]{2,20}/g) || [];
      matches.forEach(function (tag) {
        pushWord(tag.replace(/^#/, ''), 'hashtag', sourceScoreMap.hashtag);
      });
    } catch (err) {
      console.warn('[SEO keyword sync] parse hashtags failed', err);
    }
  }

  parseFromState();
  parseFromDom();
  parseFromHashtags();

  var result = {
    seedKeyword: normalizeWord(seedKeyword),
    keywords: list.slice(0, MAX_COUNT)
  };
  var packet = { source: SOURCE, type: 'data', data: result };

  var sent = false;
  try {
    if (window.opener && !window.opener.closed) {
      window.opener.postMessage(packet, '*');
      sent = true;
    }
  } catch (err) {
    console.warn('[SEO keyword sync] postMessage failed', err);
  }

  try {
    var bc = new BroadcastChannel(CHANNEL);
    bc.postMessage(packet);
    bc.close();
  } catch (err) {
    console.warn('[SEO keyword sync] BroadcastChannel failed', err);
  }

  console.log('=== XHS SEO LONGTAIL JSON START ===');
  console.log(JSON.stringify(result, null, 2));
  console.log('=== XHS SEO LONGTAIL JSON END ===');
  if (sent) {
    console.log('Payload posted back to tool page.');
  } else {
    console.log('Auto-return failed, copy JSON manually into the tool page.');
  }
})();`
}

